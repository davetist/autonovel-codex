# LLM backend: "codex" uses the local Codex CLI / ChatGPT auth session.
# Use "anthropic" to keep the original direct Anthropic API behavior.
AUTONOVEL_LLM_PROVIDER=codex

# Codex backend settings. npx latest is recommended because older local codex
# builds may not support the newest configured ChatGPT model.
AUTONOVEL_CODEX_COMMAND=npx -y @openai/codex@latest
AUTONOVEL_CODEX_SANDBOX=read-only
AUTONOVEL_CODEX_TIMEOUT=1800
# AUTONOVEL_CODEX_MODEL=

# Anthropic backend settings (only required when AUTONOVEL_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
AUTONOVEL_WRITER_MODEL=claude-sonnet-4-6
AUTONOVEL_JUDGE_MODEL=claude-sonnet-4-6
AUTONOVEL_REVIEW_MODEL=claude-opus-4-6
AUTONOVEL_API_BASE_URL=https://api.anthropic.com

# fal.ai key for image generation (Nano Banana 2)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
